{
  "compatibility_date": "2025-09-06",
  "main": "src/index.ts",
  "name": "contabilidade",
  "upload_source_maps": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "openapi-template-db",
      "database_id": "a6e33081-bcba-4792-913c-382cb4e898f9"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "contabilidade-media"
    }
  ]
}
